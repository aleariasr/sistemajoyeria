# Monorepo environment references
# --------------------------------
# This root file is informational to centralize required variables by module.
# Copy and configure each module-specific file instead of this one:
# - backend/.env.example   -> backend/.env
# - frontend/.env.example  -> frontend/.env
# - storefront/.env.example -> storefront/.env.local

# Backend (required in most environments)
SESSION_SECRET=
SUPABASE_URL=
SUPABASE_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend POS / Storefront (production)
REACT_APP_API_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=
